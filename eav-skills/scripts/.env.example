# EAV Proxy Configuration
# Copy this file to scripts/.env beside eav-remote-cli.js, or rely on merge order:
#   ./.env (process.cwd(), highest among files) -> ~/.env -> scripts/.env (fallback).
# Shell-exported vars are never overwritten by files.

# EAV Proxy Server URL (required)
EAV_PROXY_URL=http://localhost:3333
