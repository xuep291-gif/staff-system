<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jfeat.processTask.mapper.TeamMapper">


    <!-- 基础列定义 -->
    <sql id="Base_Column_List">
        id, teamName, teamDesc, pid
    </sql>

    <!-- 分页查询 -->
    <select id="findTeamsPage" resultType="com.jfeat.processTask.dao.model.Team">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_team
        WHERE 1=1
        <if test="teamName != null and teamName != ''">
            AND teamName = #{record.teamName}
        </if>

        <if test="search != null and search != ''">
            AND (
            teamName LIKE CONCAT('%', #{search}, '%')
            OR teamDesc LIKE CONCAT('%', #{search}, '%')
            )
        </if>

        <if test="pid != null">
            AND pid = #{record.pid}
        </if>

        ORDER BY id ASC
        <if test="offset != null and pageSize != null">
            LIMIT #{offset}, #{pageSize}
        </if>
    </select>
</mapper>
