<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jfeat.am.module.workflow.services.persistence.dao.TaskMapper">

	<!-- 通用查询映射结果 -->
	<resultMap id="BaseResultMap" type="com.jfeat.am.module.workflow.services.persistence.model.Task">
		<id column="id" property="id" />
		<result column="user_id" property="userId" />
		<result column="process_instance_id" property="processInstanceId" />
		<result column="step_id" property="stepId" />
		<result column="form_id" property="formId" />
		<result column="form_type" property="formType" />
		<result column="status" property="status" />
		<result column="name" property="name" />
		<result column="handle_time" property="handleTime" />
	</resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, user_id AS userId, process_instance_id AS processInstanceId, step_id AS stepId, form_id AS formId, form_type AS formType, status, name, handle_time AS handleTime
    </sql>

</mapper>
