Accept: application/json
Authorization: {{token}}

{
    "currentUserId": 1,
    "code": "PROC-001",
    "formGroup": "HR-r",
    "formType": "LEAVE_APPLY",
    "name": "员工请假流程",
    "categoryId": 10,
    "status": "ENABLED",
    "openTo": "DEPARTMENT",
    "openToIds": "1,2,3",
    "orgId": 1,
    "codeRule": "HR-{YYYYMMDD}-{SEQ}",
    "allowDelete": true
}

###根据id删除工作流
#processId：工作流id
DELETE {{endpoint}}/api/adm/wf/processes/{{processId}}



