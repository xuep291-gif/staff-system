#    "status": "VERIFYING"
#  },
#  "message": "Success"
#}
#processInstanceId:工作实例id
GET {{endpoint}}/api/wf/instanceAndForm/byTableJSON/{{processInstanceId}}}


###添加数据 发起流程
#processId：工作流id
#currentStepId:当前步骤id
#其他字段是eav 实体属性对应的字段 即eav_atribute
#eav是通过工作流步骤的虚拟表单code 和 虚拟表单code， 虚拟表单再和eav关联
POST {{endpoint}}/api/wf/instances/instanceAndForm
Accept: application/json
Authorization: {{token}}

{
      "currentStepId": 1912773527836311553
      "processId": 4001,
	  "price":100,
      "name": "张三的请病假申请",
	  "category":"请假",
     "stock":100,

 }

###推荐流程
#id就是需要推进当前步骤实例id，必填项
#其他字段是下个步骤对应eav 属性字段
POST {{endpoint}}/api/wf/instances/instanceAndForm/push
Accept: application/json
Authorization: {{token}}

{
    "id":6024,
	  "level":10011111111,
      "fullName": "张三的请病假申请11111111111",
	  "address":"请假111",
    "phone":1001111111111111111
    }

###获取表单数据
#返回结果 就是上面提交表单数据字段值
#{
#	"code": 200,
#	"data": {
#		"price": "100",
