#id：工作步骤id
GET {{endpoint}}/api/adm/wf/processes/steps/{{id}}

### 添加工作流步骤
#processId：工作流id
POST {{endpoint}}/api/adm/wf/processes/{{processId}}/steps
Accept: application/json
Authorization: {{token}}

{
      "name": "HR处理",
      "type": "MIDDLE",#类型：START, MIDDLE, END
      "stepType": "approval", #步骤类型：审核步骤approval，填写步骤content
      "nextSteps": "[5001]", #下一步骤列表，逗号分隔
      "handlerSelectRule": "ROLE:manager",
      "handlerIds": "101,102", #经办人ID列表
      "currentUserId": 1001,#执行人id
      "virtualFormCode": "form_leave_apply" #虚拟表单的code
}

### 修改工作流步骤信息
#id：工作步骤id
PUT {{endpoint}}/api/adm/wf/processes/steps/{{id}}
Accept: application/json
Authorization: {{token}}

{
      "name": "发起申请",
      "type": "START",
      "stepType": "content",
      "nextSteps": [5001],
      "handlerSelectRule": "ROLE:manager",
      "handlerIds": "101,102",
      "currentUserId": 4,
      "processId":4001,
      "virtualFormCode": "form_leave_apply"
}

### 删除工作流步骤
#processId：工作流id
#id：工作步骤id
DELETE {{endpoint}}/api/adm/wf/processes/{{processId}}/steps/{{id}}


### 删除工作流步骤
#id：工作步骤id
DELETE {{endpoint}}/api/adm/wf/processes//steps/{{id}}


#end工作流步骤

















