<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jfeat.am.module.workflow.services.domain.dao.QueryTaskDao">
    <sql id="Base_Column_List">
        wf_task.*
    </sql>
    <select id="findTasks" resultType="Task">
        SELECT wf_task.*
        FROM wf_task
        WHERE 1=1

        <if test="userId != null and userId != ''">
            AND wf_task.user_id = #{userId}
        </if>

        <if test="formId != null and formId != ''">
            AND wf_task.form_id = #{formId}
        </if>

        <if test="status != null and status != ''">
            AND wf_task.status = #{status}
        </if>

        ORDER BY wf_task.id DESC
    </select>

</mapper>