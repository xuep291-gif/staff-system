<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jfeat.am.module.workflow.services.domain.dao.QueryHistoryDao">
    <sql id="Base_Column_List">
        wf_history.*
    </sql>

    <select id="findHistories" resultType="History">
        SELECT wf_history.*
        FROM wf_history
        WHERE 1 = 1
        <if test="instanceId != null and instanceId != ''">
            AND wf_history.process_instance_id = #{instanceId}
        </if>
        <if test="formId != null and formId != ''">
            AND wf_history.form_id = #{formId}
        </if>
        <if test="stepId != null and stepId != ''">
            AND wf_history.step_id = #{stepId}
        </if>
        <if test="userId != null and userId != ''">
            AND wf_history.user_id = #{userId}
        </if>

    </select>
</mapper>